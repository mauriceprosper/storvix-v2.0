rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'usestorvix@gmail.com' ||
        request.auth.token.email == 'mauriceprosper1@gmail.com'
      );
    }

    // ── Sellers ──────────────────────────────────────────
    match /sellers/{sellerId} {
      // Public read so storefront (subdomain) can fetch by slug
      allow read: if true;
      // Only owner or admin can create/update; admin can suspend
      allow create: if isOwner(sellerId);
      allow update: if isOwner(sellerId) || isAdmin();
      allow delete: if isAdmin();

      // ── Products (subcollection) ──────────────────────
      match /products/{productId} {
        allow read: if true;                 // Public for storefront
        allow write: if isOwner(sellerId);
      }

      // ── Orders (subcollection) ────────────────────────
      match /orders/{orderId} {
        // Anyone can create an order (incognito checkout)
        allow create: if true;
        // Read: owner or admin only
        allow read: if isOwner(sellerId) || isAdmin();
        // Public can update only payment-related fields (after Paystack callback);
        // owner/admin can update everything
        allow update: if isOwner(sellerId) || isAdmin()
          || request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'paymentStatus', 'paymentRef', 'updatedAt']);
        allow delete: if isAdmin();
      }

      // ── Customers ─────────────────────────────────────
      match /customers/{customerId} {
        allow read, write: if isOwner(sellerId) || isAdmin();
      }

      // ── Discounts ─────────────────────────────────────
      match /discounts/{discountId} {
        allow read: if true;
        allow write: if isOwner(sellerId);
      }

      // ── Payment Links ─────────────────────────────────
      match /paymentLinks/{linkId} {
        allow read: if true;
        allow create, update: if isOwner(sellerId);
        allow delete: if isOwner(sellerId);
      }

      // ── Transactions ──────────────────────────────────
      match /transactions/{txnId} {
        allow read: if isOwner(sellerId) || isAdmin();
        allow write: if isAdmin(); // Cloud Functions only
      }

      // ── Testimonials ──────────────────────────────────
      match /testimonials/{testimonialId} {
        allow read: if true;
        allow write: if isOwner(sellerId);
      }
    }

    // ── Withdrawals (top-level) ──────────────────────────
    match /withdrawals/{withdrawalId} {
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && resource.data.sellerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ── Cart Sessions (abandoned cart tracking) ──────────
    match /cartSessions/{sessionId} {
      allow create, update: if true;
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Admin: collectionGroup queries ───────────────────
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }

    // Catch-all: deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
