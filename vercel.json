{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "((?!www\\.)[a-z0-9-]+)\\.storvix\\.ng"
        }
      ],
      "destination": "/store.html"
    },
    { "source": "/store",      "destination": "/store.html" },
    { "source": "/store/(.*)", "destination": "/store.html" },
    { "source": "/pay",        "destination": "/pay.html" },
    { "source": "/admin",      "destination": "/admin.html" },
    { "source": "/dashboard",  "destination": "/dashboard.html" },
    { "source": "/auth",       "destination": "/auth.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/invoice",    "destination": "/invoice.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}